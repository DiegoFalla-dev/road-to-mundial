{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "npm install",
  "buildCommand": "npm run build:core && npm --workspace @rtm/api run build && npm --workspace @rtm/web run build:prod",
  "outputDirectory": "apps/web/dist/web/browser",
  "framework": null,
  "functions": {
    "api/index.ts": {
      "maxDuration": 15,
      "includeFiles": "apps/api/data/**"
    }
  },
  "rewrites": [{ "source": "/((?!api/).*)", "destination": "/index.html" }]
}
