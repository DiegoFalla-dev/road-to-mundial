# Puerto del servidor API
PORT=3000

# Fuente de datos: seed (por defecto) | snapshot | prisma
DATA_SOURCE=seed

# Ruta del snapshot JSON cuando DATA_SOURCE=snapshot (relativa al cwd de la API)
SNAPSHOT_PATH=data/worldcup-2026.snapshot.json

# Clave de API-Football (https://www.api-football.com) para el job de refresco
API_FOOTBALL_KEY=

# Conexión PostgreSQL (solo para DATA_SOURCE=prisma)
DATABASE_URL="postgresql://user:password@localhost:5432/road_to_mundial?schema=public"
