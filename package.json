{
  "name": "road-to-mundial",
  "version": "0.1.0",
  "private": true,
  "description": "Plataforma de análisis futbolístico — Mundial 2026",
  "license": "MIT",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build:core": "npm run build -w @rtm/core",
    "test:core": "npm run test -w @rtm/core",
    "dev:api": "npm run start:dev -w @rtm/api",
    "dev:web": "npm run start -w @rtm/web",
    "test:scraper": "npm run test -w @rtm/scraper",
    "refresh:data": "npm run refresh -w @rtm/scraper"
  },
  "engines": {
    "node": ">=20"
  },
  "comment": "Dependencias en la raíz para que la función serverless de Vercel (api/index.ts) resuelva NestJS/Express. La lógica real vive en los workspaces.",
  "dependencies": {
    "@nestjs/common": "^10.4.0",
    "@nestjs/core": "^10.4.0",
    "@nestjs/platform-express": "^10.4.0",
    "express": "^4.21.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  }
}
