{
  "name": "@rtm/scraper",
  "version": "0.1.0",
  "description": "Ingesta de datos del Mundial 2026: API-Football (primario) y Flashscore (respaldo) → WorldCupSnapshot",
  "private": true,
  "type": "commonjs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "node --test --import tsx ./test/*.test.ts",
    "refresh": "tsx src/refresh.ts",
    "scrape:flashscore": "tsx src/flashscore-scraper.ts"
  },
  "dependencies": {
    "@rtm/core": "*"
  },
  "optionalDependencies": {
    "playwright": "^1.48.0"
  },
  "devDependencies": {
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
